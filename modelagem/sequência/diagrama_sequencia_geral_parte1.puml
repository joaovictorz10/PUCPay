@startuml Diagrama de Sequência Geral - PUCPay Parte 1
!theme plain
skinparam sequenceArrowThickness 2
skinparam roundcorner 0
skinparam maxMessageSize 350
skinparam backgroundColor #FEFEFE
skinparam lifeline {
  BackgroundColor #E8F4F8
  BorderColor #0066CC
}
skinparam defaultFontSize 11

actor "Usuário" as User
participant "Frontend" as Frontend
participant "API" as API
participant "Auth" as Auth
participant "Validação" as Valid
database "BD" as BD
participant "Transação" as Trans
queue "RabbitMQ" as Queue
participant "Notif" as Notif

== 1. AUTENTICAÇÃO E LOGIN ==

User -> Frontend: 1. Acessar aplicação
activate Frontend
Frontend -> API: 2. GET /api/auth/status
activate API
API -> Auth: 3. Validar sessão
activate Auth

alt Sessão Válida
  Auth -> API: 4a. Autenticado
  deactivate Auth
  API -> Frontend: 5a. Dados usuário
  deactivate API
  Frontend -> User: 6a. Dashboard
  deactivate Frontend
else Sem Sessão
  Auth -> API: 4b. Erro 401
  deactivate Auth
  API -> Frontend: 5b. Exibir login
  deactivate API
  Frontend -> User: 6b. Login

  User -> Frontend: 7. Login + senha
  activate Frontend
  Frontend -> API: 8. POST /api/auth/login
  activate API
  API -> Auth: 9. Validar credenciais
  activate Auth

  alt Válido
    Auth -> BD: 10a. Consultar usuário
    activate BD
    BD -> Auth: 11a. Usuário encontrado
    deactivate BD
    Auth -> API: 12a. JWT token
    deactivate Auth
    API -> Frontend: 13a. Token
    deactivate API
    Frontend -> User: 14a. Dashboard
    deactivate Frontend
  else Inválido
    Auth -> API: 12b. Erro 401
    deactivate Auth
    API -> Frontend: 13b. Erro auth
    deactivate API
    Frontend -> User: 14b. Erro
    deactivate Frontend
  end
end

== 2. ADMINISTRADOR - ENVIAR MOEDAS ==

alt Admin
  User -> Frontend: 15. Acessar painel admin
  activate Frontend
  Frontend -> API: 16. GET /api/admin/dashboard
  activate API
  API -> BD: 17. Consultar dashboard
  activate BD
  BD -> API: 18. Estatísticas
  deactivate BD
  API -> Frontend: 19. Dashboard
  deactivate API
  Frontend -> User: 20. Exibir gráficos
  deactivate Frontend

  User -> Frontend: 21. Buscar professor
  activate Frontend
  Frontend -> API: 22. GET /api/professores/buscar
  activate API
  API -> BD: 23. Consultar professor
  activate BD
  BD -> API: 24. Professor encontrado
  deactivate BD
  API -> Frontend: 25. Exibir professor
  deactivate API
  Frontend -> User: 26. Professor selecionado
  deactivate Frontend

  User -> Frontend: 27. Informar quantidade
  activate Frontend
  Frontend -> API: 28. POST /api/moedas/enviar
  activate API
  API -> Valid: 29. Validar quantidade
  activate Valid

  alt Quantidade OK
    Valid -> API: 30a. Validado
    deactivate Valid
    API -> BD: 31a. Verificar saldo
    activate BD
    BD -> API: 32a. Saldo retornado
    deactivate BD

    alt Saldo Suficiente
      API -> Trans: 33a. BEGIN TRANSACTION
      activate Trans
      Trans -> BD: 34a. Debitar admin
      activate BD
      BD -> Trans: 35a. OK
      deactivate BD
      Trans -> BD: 36a. Creditar professor
      activate BD
      BD -> Trans: 37a. OK
      deactivate BD
      Trans -> BD: 38a. INSERT transacao
      activate BD
      BD -> Trans: 39a. OK
      deactivate BD
      Trans -> BD: 40a. COMMIT
      activate BD
      BD -> Trans: 41a. Confirmado
      deactivate BD
      deactivate Trans

      API -> Queue: 42a. Enfileirar notif
      activate Queue
      Queue -> API: 43a. Enfileirada
      deactivate Queue

      API -> Notif: 44a. Processar notif
      activate Notif
      Notif -> User: 45a. Email + Push
      Notif -> API: 46a. Enviado
      deactivate Notif

      API -> Frontend: 47a. Sucesso
      deactivate API
      Frontend -> User: 48a. Confirmação
      deactivate Frontend

    else Saldo Insuficiente
      API -> Frontend: 33b. Erro saldo
      deactivate API
      Frontend -> User: 34b. Erro
      deactivate Frontend
    end

  else Quantidade Inválida
    Valid -> API: 30b. Erro
    deactivate Valid
    API -> Frontend: 31b. Erro validação
    deactivate API
    Frontend -> User: 32b. Erro
    deactivate Frontend
  end

else Empresa

  == 3. EMPRESA - CRIAR VANTAGEM ==

  User -> Frontend: 49. Acessar criar vantagem
  activate Frontend
  Frontend -> API: 50. GET /api/vantagens/novo
  activate API
  API -> Frontend: 51. Formulário
  deactivate API
  Frontend -> User: 52. Formulário cadastro
  deactivate Frontend

  User -> Frontend: 53. Preencher dados
  activate Frontend
  Frontend -> Frontend: 54. Validar campos

  alt Válido
    Frontend -> API: 55a. POST /api/vantagens
    activate API
    API -> Valid: 56a. Validar dados
    activate Valid

    alt OK
      Valid -> API: 57a. Validado
      deactivate Valid
      API -> BD: 58a. Verificar nome único
      activate BD
      BD -> API: 59a. Disponível
      deactivate BD

      API -> Trans: 60a. BEGIN TRANSACTION
      activate Trans
      Trans -> BD: 61a. INSERT vantagem
      activate BD
      BD -> Trans: 62a. OK
      deactivate BD
      Trans -> BD: 63a. COMMIT
      activate BD
      BD -> Trans: 64a. Confirmado
      deactivate BD
      deactivate Trans

      API -> BD: 65a. Consultar alunos
      activate BD
      BD -> API: 66a. Lista alunos
      deactivate BD

      alt Encontrados
        API -> Frontend: 67a. Alunos elegíveis
        deactivate API
        Frontend -> User: 68a. Lista alunos
        deactivate Frontend

        User -> Frontend: 69. Confirmar distribuição
        activate Frontend
        Frontend -> API: 70. POST distribuir
        activate API

        API -> Trans: 71. BEGIN TRANSACTION
        activate Trans
        loop Para cada aluno
          Trans -> BD: 72. INSERT resgate
          activate BD
          BD -> Trans: 73. OK
          deactivate BD
        end
        Trans -> BD: 74. COMMIT
        activate BD
        BD -> Trans: 75. Confirmado
        deactivate BD
        deactivate Trans

        API -> Queue: 76. Enfileirar notifs
        activate Queue
        Queue -> API: 77. Enfileiradas
        deactivate Queue

        API -> Notif: 78. Processar notifs
        activate Notif
        Notif -> User: 79. Email vantagem
        Notif -> API: 80. Enviadas
        deactivate Notif

        API -> Frontend: 81. Sucesso
        deactivate API
        Frontend -> User: 82. Confirmação
        deactivate Frontend

      else Nenhum
        API -> Frontend: 67b. Aviso
        deactivate API
        Frontend -> User: 68b. Mensagem
        deactivate Frontend
      end

    else Erro
      Valid -> API: 57b. Erro
      deactivate Valid
      API -> Frontend: 58b. Erro validação
      deactivate API
      Frontend -> User: 59b. Erro
      deactivate Frontend
    end

  else Inválido
    Frontend -> User: 55b. Erro campos
    deactivate Frontend
  end

end

== 4. LOGOUT ==

User -> Frontend: 83. Logout
activate Frontend
Frontend -> API: 84. POST /api/auth/logout
activate API
API -> Frontend: 85. Redirecionar
deactivate API
Frontend -> User: 86. Login
deactivate Frontend

@enduml
