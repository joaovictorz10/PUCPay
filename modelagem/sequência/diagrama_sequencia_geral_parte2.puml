@startuml Diagrama de Sequência Geral - PUCPay Parte 2
!theme plain
skinparam sequenceArrowThickness 2
skinparam roundcorner 0
skinparam maxMessageSize 350
skinparam backgroundColor #FEFEFE
skinparam lifeline {
  BackgroundColor #E8F4F8
  BorderColor #0066CC
}
skinparam defaultFontSize 11

actor "Usuário" as User
participant "Frontend" as Frontend
participant "API" as API
participant "Validação" as Valid
database "BD" as BD
participant "Transação" as Trans
queue "RabbitMQ" as Queue
participant "Notif" as Notif

== 3.2 EMPRESA - GERENCIAR VANTAGENS ==

User -> Frontend: 1. Acessar vantagens
activate Frontend
Frontend -> API: 2. GET /api/vantagens/empresa
activate API
API -> BD: 3. Consultar vantagens
activate BD
BD -> API: 4. Vantagens retornadas
deactivate BD
API -> Frontend: 5. Exibir vantagens
deactivate API
Frontend -> User: 6. Lista vantagens
deactivate Frontend

User -> Frontend: 7. Editar vantagem
activate Frontend
Frontend -> API: 8. PUT /api/vantagens/{id}
activate API
API -> Valid: 9. Validar dados
activate Valid

alt Válido
  Valid -> API: 10a. OK
  deactivate Valid
  API -> Trans: 11a. BEGIN TRANSACTION
  activate Trans
  Trans -> BD: 12a. UPDATE vantagem
  activate BD
  BD -> Trans: 13a. COMMIT
  deactivate BD
  deactivate Trans
  API -> Frontend: 14a. Sucesso
  deactivate API
  Frontend -> User: 15a. Atualizada
  deactivate Frontend
else Inválido
  Valid -> API: 10b. Erro
  deactivate Valid
  API -> Frontend: 11b. Erro
  deactivate API
  Frontend -> User: 12b. Erro
  deactivate Frontend
end

User -> Frontend: 16. Deletar vantagem
activate Frontend
Frontend -> API: 17. DELETE /api/vantagens/{id}
activate API
API -> Trans: 18. BEGIN TRANSACTION
activate Trans
Trans -> BD: 19. DELETE vantagem
activate BD
BD -> Trans: 20. COMMIT
deactivate BD
deactivate Trans
API -> Frontend: 21. Sucesso
deactivate API
Frontend -> User: 22. Deletada
deactivate Frontend

== 3.3 EMPRESA - RELATÓRIOS ==

User -> Frontend: 23. Acessar relatórios
activate Frontend
Frontend -> API: 24. GET /api/empresa/relatorios
activate API
API -> BD: 25. Consultar dados
activate BD
BD -> API: 26. Estatísticas
deactivate BD
API -> Frontend: 27. Gráficos
deactivate API
Frontend -> User: 28. Relatórios
deactivate Frontend

== 4. PROFESSOR - MOEDAS RECEBIDAS ==

alt Professor
  User -> Frontend: 29. Dashboard professor
  activate Frontend
  Frontend -> API: 30. GET /api/professor/dashboard
  activate API
  API -> BD: 31. Consultar saldo
  activate BD
  BD -> API: 32. Saldo retornado
  deactivate BD
  API -> Frontend: 33. Exibir saldo
  deactivate API
  Frontend -> User: 34. Saldo de moedas
  deactivate Frontend

  User -> Frontend: 35. Histórico moedas
  activate Frontend
  Frontend -> API: 36. GET /api/professor/moedas
  activate API
  API -> BD: 37. Consultar transações
  activate BD
  BD -> API: 38. Histórico retornado
  deactivate BD
  API -> Frontend: 39. Exibir histórico
  deactivate API
  Frontend -> User: 40. Histórico detalhado
  deactivate Frontend

else Aluno

  == 5. ALUNO - VER VANTAGENS ==

  User -> Frontend: 41. Acessar vantagens
  activate Frontend
  Frontend -> API: 42. GET /api/vantagens/disponiveis
  activate API
  API -> BD: 43. Consultar vantagens ativas
  activate BD
  BD -> API: 44. Vantagens retornadas
  deactivate BD
  API -> Frontend: 45. Exibir vantagens
  deactivate API
  Frontend -> User: 46. Lista vantagens
  deactivate Frontend

  User -> Frontend: 47. Ver detalhes
  activate Frontend
  Frontend -> API: 48. GET /api/vantagens/{id}
  activate API
  API -> BD: 49. Consultar detalhes
  activate BD
  BD -> API: 50. Detalhes retornados
  deactivate BD
  API -> Frontend: 51. Exibir detalhes
  deactivate API
  Frontend -> User: 52. Descrição completa
  deactivate Frontend

  == 5.2 ALUNO - RESGATAR VANTAGEM ==

  User -> Frontend: 53. Clicar resgatar
  activate Frontend
  Frontend -> API: 54. POST /api/resgates
  activate API
  API -> Valid: 55. Validar resgate
  activate Valid

  alt Válido
    Valid -> API: 56a. Pode resgatar
    deactivate Valid
    API -> Trans: 57a. BEGIN TRANSACTION
    activate Trans
    Trans -> BD: 58a. INSERT resgate
    activate BD
    BD -> Trans: 59a. OK
    deactivate BD
    Trans -> BD: 60a. Debitar moedas
    activate BD
    BD -> Trans: 61a. OK
    deactivate BD
    Trans -> BD: 62a. COMMIT
    activate BD
    BD -> Trans: 63a. Confirmado
    deactivate BD
    deactivate Trans

    API -> Queue: 64a. Enfileirar notif
    activate Queue
    Queue -> API: 65a. Enfileirada
    deactivate Queue

    API -> Notif: 66a. Processar notif
    activate Notif
    Notif -> User: 67a. Confirmação resgate
    Notif -> API: 68a. Enviada
    deactivate Notif

    API -> Frontend: 69a. Sucesso
    deactivate API
    Frontend -> User: 70a. Resgate confirmado
    deactivate Frontend

  else Inválido
    Valid -> API: 56b. Não pode resgatar
    deactivate Valid
    API -> Frontend: 57b. Motivo negação
    deactivate API
    Frontend -> User: 58b. Erro resgate
    deactivate Frontend
  end

  == 5.3 ALUNO - HISTÓRICO ==

  User -> Frontend: 59. Acessar histórico
  activate Frontend
  Frontend -> API: 60. GET /api/aluno/historico
  activate API
  API -> BD: 61. Consultar transações
  activate BD
  BD -> API: 62. Histórico retornado
  deactivate BD
  API -> Frontend: 63. Exibir histórico
  deactivate API
  Frontend -> User: 64. Histórico completo
  deactivate Frontend

end

== 6. NOTIFICAÇÕES GLOBAIS ==

API -> Queue: 65. POST /api/notificacoes
activate Queue
Queue -> API: 66. Enfileirada
activate Notif
Notif -> Notif: 67. Processar fila

par Canais Notificação
  Notif -> User: 68. Email
  Notif -> User: 69. Push Notification
  Notif -> Frontend: 70. In-app
end

Notif -> API: 71. Confirmação envio
deactivate Notif
deactivate Queue

== 7. LOGOUT ==

User -> Frontend: 72. Logout
activate Frontend
Frontend -> API: 73. POST /api/auth/logout
activate API
API -> Frontend: 74. Redirecionar
deactivate API
Frontend -> User: 75. Login
deactivate Frontend

@enduml
